[32m+[m[32m    def _restore_fit_progress_for_evaluation(self, fit_loop_state_dict: dict[str, Any]) -> None:[m
[32m+[m[32m        """Restores the fit-loop counters that back ``trainer.current_epoch`` and ``trainer.global_step``.[m
[32m+[m
[32m+[m[32m        Evaluation-only entry points should not load the full fit loop because that marks the loop as restarting.[m
[32m+[m[32m        However, loggers and hooks still read their epoch and step from the fit-loop progress.[m
[32m+[m
[32m+[m[32m        """[m
[32m+[m[32m        fit_loop = self.trainer.fit_loop[m
[32m+[m[32m        fit_loop.epoch_progress.load_state_dict(fit_loop_state_dict["epoch_progress"])[m
[32m+[m[32m        fit_loop.epoch_loop.automatic_optimization.optim_progress.load_state_dict([m
[32m+[m[32m            fit_loop_state_dict["epoch_loop.automatic_optimization.optim_progress"][m
[32m+[m[32m        )[m
[32m+[m[32m        fit_loop.epoch_loop.manual_optimization.optim_step_progress.load_state_dict([m
[32m+[m[32m            fit_loop_state_dict["epoch_loop.manual_optimization.optim_step_progress"][m
[32m+[m[32m        )[m
[32m+[m[32m        fit_loop.epoch_loop.on_load_checkpoint(fit_loop_state_dict["epoch_loop.state_dict"])[m
[32m+[m
