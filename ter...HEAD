[32m+[m[32mdef test_test_ckpt_path_restores_fit_progress_for_test_hooks(tmp_path):[m
[32m+[m[32m    checkpoint_callback = ModelCheckpoint(dirpath=tmp_path, filename="{epoch}", save_top_k=-1)[m
[32m+[m
[32m+[m[32m    class TestModel(BoringModel):[m
[32m+[m[32m        def __init__(self):[m
[32m+[m[32m            super().__init__()[m
[32m+[m[32m            self.on_test_start_current_epoch = None[m
[32m+[m[32m            self.on_test_start_global_step = None[m
[32m+[m
[32m+[m[32m        def on_test_start(self):[m
[32m+[m[32m            self.on_test_start_current_epoch = self.trainer.current_epoch[m
[32m+[m[32m            self.on_test_start_global_step = self.trainer.global_step[m
[32m+[m
[32m+[m[32m    model = TestModel()[m
[32m+[m[32m    trainer = Trainer([m
[32m+[m[32m        default_root_dir=tmp_path,[m
[32m+[m[32m        max_epochs=3,[m
[32m+[m[32m        limit_train_batches=2,[m
[32m+[m[32m        limit_val_batches=0,[m
[32m+[m[32m        limit_test_batches=1,[m
[32m+[m[32m        callbacks=[checkpoint_callback],[m
[32m+[m[32m        enable_progress_bar=False,[m
[32m+[m[32m        logger=False,[m
[32m+[m[32m    )[m
[32m+[m[32m    trainer.fit(model)[m
[32m+[m[32m    assert trainer.current_epoch == 3[m
[32m+[m
[32m+[m[32m    checkpoint_path = tmp_path / "epoch=1.ckpt"[m
[32m+[m[32m    checkpoint = torch.load(checkpoint_path, weights_only=False)[m
[32m+[m
[32m+[m[32m    trainer.test(model, ckpt_path=checkpoint_path, verbose=False)[m
[32m+[m
[32m+[m[32m    assert (model.on_test_start_current_epoch, model.on_test_start_global_step) == ([m
[32m+[m[32m        checkpoint["epoch"],[m
[32m+[m[32m        checkpoint["global_step"],[m
[32m+[m[32m    )[m
[32m+[m
